# ============================================================
# SmartLift API — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to source control.
# ============================================================

# ----- Database -----
# MariaDB / MySQL connection string.
# timezone=UTC ensures all TIMESTAMP values are stored and read in UTC,
# which prevents Date serialization issues with the Prisma MariaDB adapter.
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/smartlift?timezone=UTC"

# ----- JWT -----
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"
JWT_EXPIRES_IN="7d"

# ----- App -----
PORT=3000
NODE_ENV=development
