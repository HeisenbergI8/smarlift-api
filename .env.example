# ============================================================
# SmartLift API — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to source control.
# ============================================================

# ----- Database -----
# Local MariaDB / MySQL:
# DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/smartlift?timezone=UTC"
#
# TiDB Cloud Serverless (free tier) — get connection string from:
# TiDB Cloud Console → Cluster → Connect → General
# Format: mariadb://<user>.<cluster>:<password>@<host>:4000/<db>?ssl=true&timezone=UTC
DATABASE_URL="mariadb://user.cluster:password@gateway.region.prod.aws.tidbcloud.com:4000/smartlift?ssl=true&timezone=UTC"

# ----- JWT -----
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"
JWT_EXPIRES_IN="7d"

# ----- App -----
PORT=3000
NODE_ENV=development
